# ── Server ────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# Public-facing base URL of your deployment — used in unsubscribe links sent
# via email, SMS, and WhatsApp. No trailing slash.
# Example for a Vercel deployment: https://tehillim-for-tilim.vercel.app
BASE_URL=https://your-domain.com

# ── Admin ─────────────────────────────────────────────────
# Secret key to protect GET /api/admin.
# Pass as ?key=<value> or Authorization: Bearer <value>.
# Generate a strong random string, e.g.: openssl rand -hex 32
ADMIN_KEY=replace_with_a_strong_random_secret

# ── Alert Settings ────────────────────────────────────────
# How often (in seconds) to poll the Pikud Ha'oref API for new alerts.
POLL_INTERVAL_SECONDS=5

# Minimum seconds between re-notifying the same subscriber during a prolonged alert.
ALERT_COOLDOWN_SECONDS=120

# ── EmailJS (Email Notifications) ────────────────────────
# Sign up at https://emailjs.com — free tier: 200 emails/month.
# Keys are under Account → API Keys; Service ID and Template IDs under
# Email Services and Email Templates respectively.
EMAILJS_PUBLIC_KEY=your_public_key_here
EMAILJS_PRIVATE_KEY=your_private_key_here
EMAILJS_SERVICE_ID=service_xxxxxxx

# Template used for rocket alert emails.
EMAILJS_TEMPLATE_ID=template_xxxxxxx

# Template used for welcome emails sent on signup.
# If omitted, the alert template (EMAILJS_TEMPLATE_ID) is used as a fallback.
EMAILJS_WELCOME_TEMPLATE_ID=template_xxxxxxx

# ── Twilio (SMS + WhatsApp) ───────────────────────────────
# Sign up at https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Your Twilio phone number for outbound SMS (E.164 format).
TWILIO_FROM_NUMBER=+15550000000

# ── Twilio WhatsApp ───────────────────────────────────────
# SANDBOX (free testing — users must send "join <word>" to +14155238886 once):
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# PRODUCTION (after applying for a WhatsApp Business number in Twilio console):
# TWILIO_WHATSAPP_FROM=whatsapp:+1XXXXXXXXXX
